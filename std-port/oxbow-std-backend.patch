+// --- TCP: in-process loopback socketpair + net-server client -----------------
+
+use crate::sync::atomic::AtomicU64;
+
+/// One direction of a loopback connection: a byte FIFO plus a "writer closed" flag
+/// (set when the writing endpoint shuts down its write half or is fully dropped).
+struct Half {
+    data: Mutex<VecDeque<u8>>,
+    wshut: AtomicBool,
+}
+impl Half {
+    fn new() -> Half {
+        Half { data: Mutex::new(VecDeque::new()), wshut: AtomicBool::new(false) }
+    }
+}
+
+/// A loopback connection shared by both endpoints.
+struct Conn {
+    c2s: Half, // client -> server
+    s2c: Half, // server -> client
+    caddr: SocketAddr,
+    saddr: SocketAddr,
+}
+
+/// One endpoint of a loopback connection; shared by clones via `Arc`.
+struct Endpoint {
+    conn: Arc<Conn>,
+    server: bool,
+    nonblocking: AtomicBool,
+    rd_timeout: Mutex<Option<Duration>>,
+    wr_timeout: Mutex<Option<Duration>>,
+    rshut: AtomicBool,
+    ttl: AtomicU32,
+    nodelay: AtomicBool,
+    keepalive: AtomicBool,
+    linger: Mutex<Option<Duration>>,
+}
+impl Endpoint {
+    fn rhalf(&self) -> &Half {
+        if self.server { &self.conn.c2s } else { &self.conn.s2c }
+    }
+    fn whalf(&self) -> &Half {
+        if self.server { &self.conn.s2c } else { &self.conn.c2s }
+    }
+    fn local(&self) -> SocketAddr {
+        if self.server { self.conn.saddr } else { self.conn.caddr }
+    }
+    fn peer(&self) -> SocketAddr {
+        if self.server { self.conn.caddr } else { self.conn.saddr }
+    }
+}
+impl Drop for Endpoint {
+    fn drop(&mut self) {
+        // Last clone gone: signal EOF to the peer's reader.
+        self.whalf().wshut.store(true, Ordering::Relaxed);
+    }
+}
+
+/// A net-server-backed (external, non-loopback) TCP client stream.
+struct NetStream {
+    sock: i64,
+    peer: SocketAddr,
+}
+impl Drop for NetStream {
+    fn drop(&mut self) {
+        unsafe { __oxbow_tcp_close(self.sock) };
+    }
+}
+
+enum Stream {
+    Loop(Arc<Endpoint>),
+    Net(Arc<NetStream>),
+}
+pub struct TcpStream(Stream);
+
+/// A listening address: an accept queue of pending connections. Entries persist for
+/// the process lifetime (tests bind unique ports), so `bind` of an existing address
+/// reports `AddrInUse` and a missing one yields `ConnectionRefused` on connect.
+struct ListenerEntry {
+    id: u64,
+    addr: SocketAddr,
+    queue: VecDeque<Arc<Conn>>,
+    nonblocking: bool,
+    ttl: u32,
+}
+static LISTENERS: Mutex<Vec<ListenerEntry>> = Mutex::new(Vec::new());
+static NEXT_LID: AtomicU64 = AtomicU64::new(1);
+static TCP_EPHEMERAL: AtomicU32 = AtomicU32::new(50000);
+
+/// A net-server-backed (wire) listening socket.
+struct NetListener {
+    sock: i64,
+    addr: SocketAddr,
+    nonblocking: AtomicBool,
+}
+impl Drop for NetListener {
+    fn drop(&mut self) {
+        unsafe { __oxbow_tcp_close(self.sock) };
+    }
+}
+
+enum ListenerKind {
+    /// In-process loopback listener, keyed into the `LISTENERS` registry by `id`.
+    Loop { id: u64, addr: SocketAddr },
+    /// Real listening socket in the net server's smoltcp stack.
+    Net(Arc<NetListener>),
+}
+pub struct TcpListener(ListenerKind);
+
+fn loopback_like(template: &SocketAddr, port: u16) -> SocketAddr {
+    match template {
+        SocketAddr::V4(_) => SocketAddr::V4(SocketAddrV4::new(Ipv4Addr::LOCALHOST, port)),
+        SocketAddr::V6(_) => SocketAddr::V6(SocketAddrV6::new(Ipv6Addr::LOCALHOST, port, 0, 0)),
+    }
+}
+
+impl TcpStream {
+    pub fn connect<A: ToSocketAddrs>(addr: A) -> io::Result<TcpStream> {
+        let addr = first_addr(addr)?;
+        if is_loopback_or_unspec(&addr) {
+            // Loopback: pair with an in-process listener.
+            let cport = TCP_EPHEMERAL.fetch_add(1, Ordering::Relaxed) as u16;
+            let conn = Arc::new(Conn {
+                c2s: Half::new(),
+                s2c: Half::new(),
+                caddr: loopback_like(&addr, cport),
+                saddr: addr,
+            });
+            let mut ls = LISTENERS.lock().unwrap();
+            let entry = ls
+                .iter_mut()
+                .find(|e| e.addr == addr)
+                .ok_or_else(|| io::const_error!(ErrorKind::ConnectionRefused, "connection refused"))?;
+            entry.queue.push_back(conn.clone());
+            drop(ls);
+            Ok(TcpStream(Stream::Loop(Arc::new(new_endpoint(conn, false)))))
+        } else {
+            // External: real client via the net server (IPv4 or IPv6, both on the wire).
+            let sock = match &addr {
+                SocketAddr::V4(s) => {
+                    let ip = u32::from_be_bytes(s.ip().octets());
+                    unsafe { __oxbow_tcp_connect(ip, addr.port()) }
+                }
+                SocketAddr::V6(s) => {
+                    let octets = s.ip().octets();
+                    unsafe { __oxbow_tcp_connect6(octets.as_ptr(), addr.port()) }
+                }
+            };
+            if sock < 0 {
+                return Err(io::const_error!(ErrorKind::ConnectionRefused, "connection refused"));
+            }
+            Ok(TcpStream(Stream::Net(Arc::new(NetStream { sock, peer: addr }))))
+        }
+    }
+
+    pub fn connect_timeout(addr: &SocketAddr, timeout: Duration) -> io::Result<TcpStream> {
+        if timeout == Duration::ZERO {
+            return Err(io::const_error!(ErrorKind::InvalidInput, "cannot set a 0 duration timeout"));
+        }
+        if is_loopback_or_unspec(addr) {
+            return Self::connect(*addr);
+        }
+        // External connect can't honor a deadline through the blocking net call; treat a
+        // refused/failed connect as a timeout (the test uses a non-routable address).
+        let sock = match addr {
+            SocketAddr::V4(s) => unsafe {
+                __oxbow_tcp_connect(u32::from_be_bytes(s.ip().octets()), addr.port())
+            },
+            SocketAddr::V6(s) => unsafe { __oxbow_tcp_connect6(s.ip().octets().as_ptr(), addr.port()) },
+        };
+        if sock < 0 {
+            return Err(io::const_error!(ErrorKind::TimedOut, "connection timed out"));
+        }
+        Ok(TcpStream(Stream::Net(Arc::new(NetStream { sock, peer: *addr }))))
+    }
+
+    fn ep(&self) -> io::Result<&Endpoint> {
+        match &self.0 {
+            Stream::Loop(e) => Ok(e),
+            Stream::Net(_) => Err(io::const_error!(ErrorKind::Unsupported, "not a loopback stream")),
+        }
+    }
+
+    pub fn set_read_timeout(&self, t: Option<Duration>) -> io::Result<()> {
+        UdpSocket::set_timeout(&self.ep()?.rd_timeout, t)
+    }
+    pub fn set_write_timeout(&self, t: Option<Duration>) -> io::Result<()> {
+        UdpSocket::set_timeout(&self.ep()?.wr_timeout, t)
+    }
+    pub fn read_timeout(&self) -> io::Result<Option<Duration>> {
+        Ok(*self.ep()?.rd_timeout.lock().unwrap())
+    }
+    pub fn write_timeout(&self) -> io::Result<Option<Duration>> {
+        Ok(*self.ep()?.wr_timeout.lock().unwrap())
+    }
+
+    fn loop_read(ep: &Endpoint, buf: &mut [u8], consume: bool) -> io::Result<usize> {
+        if buf.is_empty() {
+            return Ok(0);
+        }
+        let deadline = ep.rd_timeout.lock().unwrap().map(|d| Instant::now() + d);
+        loop {
+            if ep.rshut.load(Ordering::Relaxed) {
+                return Ok(0);
+            }
+            {
+                let mut q = ep.rhalf().data.lock().unwrap();
+                if !q.is_empty() {
+                    let n = q.len().min(buf.len());
+                    for (i, slot) in buf.iter_mut().enumerate().take(n) {
+                        *slot = if consume { q.pop_front().unwrap() } else { q[i] };
+                    }
+                    return Ok(n);
+                }
+                if ep.rhalf().wshut.load(Ordering::Relaxed) {
+                    return Ok(0); // peer's writer closed and FIFO drained -> EOF
+                }
+            }
+            if ep.nonblocking.load(Ordering::Relaxed) {
+                return Err(io::const_error!(ErrorKind::WouldBlock, "operation would block"));
+            }
+            if let Some(dl) = deadline {
+                if Instant::now() >= dl {
+                    return Err(io::const_error!(ErrorKind::WouldBlock, "read timed out"));
+                }
+            }
+            crate::thread::yield_now();
+        }
+    }
+
+    pub fn read(&self, buf: &mut [u8]) -> io::Result<usize> {
+        match &self.0 {
+            Stream::Loop(e) => Self::loop_read(e, buf, true),
+            Stream::Net(s) => {
+                let n = unsafe { __oxbow_tcp_recv(s.sock, buf.as_mut_ptr(), buf.len()) };
+                if n < 0 { Ok(0) } else { Ok(n as usize) }
+            }
+        }
+    }
+
+    pub fn peek(&self, buf: &mut [u8]) -> io::Result<usize> {
+        Self::loop_read(self.ep()?, buf, false)
+    }
+
+    pub fn read_buf(&self, mut cursor: BorrowedCursor<'_>) -> io::Result<()> {
+        let mut tmp = [0u8; 2048];
+        let cap = cursor.capacity().min(tmp.len());
+        let n = self.read(&mut tmp[..cap])?;
+        cursor.append(&tmp[..n]);
+        Ok(())
+    }
+    pub fn read_vectored(&self, bufs: &mut [IoSliceMut<'_>]) -> io::Result<usize> {
+        for b in bufs {
+            if !b.is_empty() {
+                return self.read(b);
+            }
+        }
+        Ok(0)
+    }
+    pub fn is_read_vectored(&self) -> bool {
+        false
+    }
+
+    pub fn write(&self, buf: &[u8]) -> io::Result<usize> {
+        match &self.0 {
+            Stream::Loop(e) => {
+                if e.whalf().wshut.load(Ordering::Relaxed) {
+                    return Err(io::const_error!(ErrorKind::BrokenPipe, "write on a shut-down stream"));
+                }
+                e.whalf().data.lock().unwrap().extend(buf.iter().copied());
+                Ok(buf.len())
+            }
+            Stream::Net(s) => {
+                let n = unsafe { __oxbow_tcp_send(s.sock, buf.as_ptr(), buf.len()) };
+                if n < 0 {
+                    Err(io::const_error!(ErrorKind::BrokenPipe, "tcp send failed"))
+                } else {
+                    Ok(n as usize)
+                }
+            }
+        }
+    }
+    pub fn write_vectored(&self, bufs: &[IoSlice<'_>]) -> io::Result<usize> {
+        for b in bufs {
+            if !b.is_empty() {
+                return self.write(b);
+            }
+        }
+        Ok(0)
+    }
+    pub fn is_write_vectored(&self) -> bool {
+        false
+    }
+
+    pub fn peer_addr(&self) -> io::Result<SocketAddr> {
+        match &self.0 {
+            Stream::Loop(e) => Ok(e.peer()),
+            Stream::Net(s) => Ok(s.peer),
+        }
+    }
+    pub fn socket_addr(&self) -> io::Result<SocketAddr> {
+        match &self.0 {
+            Stream::Loop(e) => Ok(e.local()),
+            Stream::Net(_) => Err(io::const_error!(ErrorKind::Unsupported, "no local addr")),
+        }
+    }
+    pub fn shutdown(&self, how: Shutdown) -> io::Result<()> {
+        match &self.0 {
+            Stream::Loop(e) => {
+                match how {
+                    Shutdown::Write => e.whalf().wshut.store(true, Ordering::Relaxed),
+                    Shutdown::Read => e.rshut.store(true, Ordering::Relaxed),
+                    Shutdown::Both => {
+                        e.whalf().wshut.store(true, Ordering::Relaxed);
+                        e.rshut.store(true, Ordering::Relaxed);
+                    }
+                }
+                Ok(())
+            }
+            Stream::Net(s) => {
+                unsafe { __oxbow_tcp_close(s.sock) };
+                Ok(())
+            }
+        }
+    }
+    pub fn duplicate(&self) -> io::Result<TcpStream> {
+        Ok(TcpStream(match &self.0 {
+            Stream::Loop(e) => Stream::Loop(e.clone()),
+            Stream::Net(s) => Stream::Net(s.clone()),
+        }))
+    }
+    pub fn set_linger(&self, d: Option<Duration>) -> io::Result<()> {
+        *self.ep()?.linger.lock().unwrap() = d;
+        Ok(())
+    }
+    pub fn linger(&self) -> io::Result<Option<Duration>> {
+        Ok(*self.ep()?.linger.lock().unwrap())
+    }
+    pub fn set_keepalive(&self, v: bool) -> io::Result<()> {
+        self.ep()?.keepalive.store(v, Ordering::Relaxed);
+        Ok(())
+    }
+    pub fn keepalive(&self) -> io::Result<bool> {
+        Ok(self.ep()?.keepalive.load(Ordering::Relaxed))
+    }
+    pub fn set_nodelay(&self, v: bool) -> io::Result<()> {
+        self.ep()?.nodelay.store(v, Ordering::Relaxed);
+        Ok(())
+    }
+    pub fn nodelay(&self) -> io::Result<bool> {
+        Ok(self.ep()?.nodelay.load(Ordering::Relaxed))
+    }
+    pub fn set_ttl(&self, ttl: u32) -> io::Result<()> {
+        self.ep()?.ttl.store(ttl, Ordering::Relaxed);
+        Ok(())
+    }
+    pub fn ttl(&self) -> io::Result<u32> {
+        Ok(self.ep()?.ttl.load(Ordering::Relaxed))
+    }
+    pub fn take_error(&self) -> io::Result<Option<io::Error>> {
+        Ok(None)
+    }
+    pub fn set_nonblocking(&self, nonblocking: bool) -> io::Result<()> {
+        if let Stream::Loop(e) = &self.0 {
+            e.nonblocking.store(nonblocking, Ordering::Relaxed);
+        }
+        Ok(())
+    }
+}
+
+fn new_endpoint(conn: Arc<Conn>, server: bool) -> Endpoint {
+    Endpoint {
+        conn,
+        server,
+        nonblocking: AtomicBool::new(false),
+        rd_timeout: Mutex::new(None),
+        wr_timeout: Mutex::new(None),
+        rshut: AtomicBool::new(false),
+        ttl: AtomicU32::new(64),
+        nodelay: AtomicBool::new(false),
+        keepalive: AtomicBool::new(false),
+        linger: Mutex::new(None),
+    }
+}
