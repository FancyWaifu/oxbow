diff --git a/library/std/src/sys/net/connection/oxbow.rs b/library/std/src/sys/net/connection/oxbow.rs
new file mode 100644
index 00000000..78ee1cd7
--- /dev/null
+++ b/library/std/src/sys/net/connection/oxbow.rs
@@ -0,0 +1,938 @@
+//! oxbow network backend.
+//!
+//! oxbow's kernel net stack (e1000 → ARP/IPv4/UDP, smoltcp TCP) is reached by C/libc
+//! programs through the net server's socket-capability API, but the server has **no
+//! loopback path** — a datagram to `127.0.0.1`/`::1` would be ARP'd onto the wire.
+//! The Rust `std::net` UDP test-suite is entirely loopback, single-process, so this
+//! backend implements **`UdpSocket` as an in-process loopback** (both IPv4 and IPv6):
+//! bound sockets share a process-global mailbox table keyed by port, and `send_to` to
+//! a loopback/unspecified address enqueues into the destination's mailbox. That gives
+//! real datagram, connect/send/recv, peek, timeout, non-blocking, and clone semantics
+//! without touching the kernel.
+//!
+//! TCP is handled the same way: the net server's TCP is client-only (no listen/accept)
+//! and can't loop back, while the std `tcp` suite is loopback + single-process — so
+//! `TcpListener` + loopback `TcpStream` are an **in-process socketpair** (per-direction
+//! byte FIFOs, an accept queue per listening address, clones sharing the endpoint via
+//! `Arc`). `TcpStream::connect` to a *non-loopback* address and `UdpSocket` bound to /
+//! sending to a non-loopback address route to the **real net server** via the rt
+//! `__oxbow_{tcp,udp}_*` shims. Only `TcpListener` on a non-loopback address (the net
+//! server has no accept) stays unsupported.
+
+use crate::collections::VecDeque;
+use crate::fmt;
+use crate::io::{self, BorrowedCursor, ErrorKind, IoSlice, IoSliceMut};
+use crate::net::{Ipv4Addr, Ipv6Addr, Shutdown, SocketAddr, SocketAddrV4, SocketAddrV6, ToSocketAddrs};
+use crate::sync::Arc;
+use crate::sync::Mutex;
+use crate::sync::atomic::{AtomicBool, AtomicU32, Ordering};
+use crate::sys::unsupported;
+use crate::time::{Duration, Instant};
+
+// rt hosted shims onto the net server's socket-capability API (NET_CTL = handle 20).
+unsafe extern "C" {
+    // UDP: bind returns a socket handle (>=0) and writes the bound port; <0 on failure.
+    fn __oxbow_udp_bind(ip_be: u32, port: u16, out_port: *mut u16) -> i64;
+    fn __oxbow_udp_send_to(sock: i64, ip_be: u32, port: u16, buf: *const u8, len: usize) -> isize;
+    // recv writes the sender ip/port; returns payload len, or -1 if nothing is buffered.
+    fn __oxbow_udp_recv_from(sock: i64, buf: *mut u8, len: usize, src_ip: *mut u32, src_port: *mut u16) -> isize;
+    fn __oxbow_udp_close(sock: i64);
+    // TCP client: connect returns a socket handle (>=0) or <0; send/recv ride it.
+    fn __oxbow_tcp_connect(ip_be: u32, port: u16) -> i64;
+    fn __oxbow_tcp_connect6(addr16: *const u8, port: u16) -> i64;
+    fn __oxbow_tcp_send(sock: i64, buf: *const u8, len: usize) -> isize;
+    fn __oxbow_tcp_recv(sock: i64, buf: *mut u8, len: usize) -> isize;
+    fn __oxbow_tcp_close(sock: i64);
+    // TCP server: listen returns a listener handle (>=0); accept is non-blocking and
+    // returns a connected socket handle (>=0) + writes the peer, or <0 if none pending.
+    fn __oxbow_tcp_listen(port: u16) -> i64;
+    // accept writes the 16-byte peer address (v4 in the first 4), an is_v6 flag, the port.
+    fn __oxbow_tcp_accept(listener: i64, peer_ip16: *mut u8, is_v6: *mut u8, peer_port: *mut u16) -> i64;
+    // DNS: resolve a hostname to a big-endian IPv4 (A) / 16-byte IPv6 (AAAA); 0 on success.
+    fn __oxbow_dns_resolve(name: *const u8, len: usize, out_ip: *mut u32) -> i32;
+    fn __oxbow_dns_resolve6(name: *const u8, len: usize, out_ip16: *mut u8) -> i32;
+}
+
+fn v4_be(a: &SocketAddr) -> Option<u32> {
+    match a {
+        SocketAddr::V4(s) => Some(u32::from_be_bytes(s.ip().octets())),
+        SocketAddr::V6(_) => None,
+    }
+}
+use crate::vec::Vec;
+
+// --- in-process UDP loopback -------------------------------------------------
+
+struct Mailbox {
+    port: u16,
+    queue: VecDeque<(SocketAddr, Vec<u8>)>,
+}
+static LOOPBACK: Mutex<Vec<Mailbox>> = Mutex::new(Vec::new());
+static EPHEMERAL: AtomicU32 = AtomicU32::new(49152);
+
+fn first_addr<A: ToSocketAddrs>(addr: A) -> io::Result<SocketAddr> {
+    addr.to_socket_addrs()?
+        .next()
+        .ok_or_else(|| io::const_error!(ErrorKind::InvalidInput, "no socket address"))
+}
+
+fn is_loopback_or_unspec(a: &SocketAddr) -> bool {
+    match a {
+        SocketAddr::V4(s) => s.ip().is_loopback() || s.ip().is_unspecified(),
+        SocketAddr::V6(s) => s.ip().is_loopback() || s.ip().is_unspecified(),
+    }
+}
+
+fn with_port(a: &SocketAddr, port: u16) -> SocketAddr {
+    match a {
+        SocketAddr::V4(s) => SocketAddr::V4(SocketAddrV4::new(*s.ip(), port)),
+        SocketAddr::V6(s) => {
+            SocketAddr::V6(SocketAddrV6::new(*s.ip(), port, s.flowinfo(), s.scope_id()))
+        }
+    }
+}
+
+pub struct UdpSocket {
+    local: SocketAddr,
+    peer: Mutex<Option<SocketAddr>>,
+    nonblocking: AtomicBool,
+    read_timeout: Mutex<Option<Duration>>,
+    write_timeout: Mutex<Option<Duration>>,
+    ttl: AtomicU32,
+    // Lazily-bound net-server UDP socket: created the first time this socket sends to a
+    // non-loopback address, so loopback-only sockets never touch the net server.
+    net_sock: Mutex<Option<i64>>,
+}
+
+impl UdpSocket {
+    /// Ensure a net-server UDP socket exists for external (wire) traffic; returns its
+    /// handle, or an error if the net server can't allocate one.
+    fn ensure_net_sock(&self) -> io::Result<i64> {
+        let mut g = self.net_sock.lock().unwrap();
+        if let Some(h) = *g {
+            return Ok(h);
+        }
+        let mut out_port = 0u16;
+        let h = unsafe { __oxbow_udp_bind(0, self.local.port(), &mut out_port) };
+        if h < 0 {
+            return Err(io::const_error!(ErrorKind::AddrNotAvailable, "net: no udp socket"));
+        }
+        *g = Some(h);
+        Ok(h)
+    }
+
+    pub fn bind<A: ToSocketAddrs>(addr: A) -> io::Result<UdpSocket> {
+        let addr = first_addr(addr)?;
+        if !is_loopback_or_unspec(&addr) {
+            return Err(io::const_error!(
+                ErrorKind::AddrNotAvailable,
+                "oxbow net: only loopback UDP is supported",
+            ));
+        }
+        let port = if addr.port() == 0 {
+            EPHEMERAL.fetch_add(1, Ordering::Relaxed) as u16
+        } else {
+            addr.port()
+        };
+        let local = with_port(&addr, port);
+        let mut lb = LOOPBACK.lock().unwrap();
+        if !lb.iter().any(|m| m.port == port) {
+            lb.push(Mailbox { port, queue: VecDeque::new() });
+        }
+        Ok(UdpSocket {
+            local,
+            peer: Mutex::new(None),
+            nonblocking: AtomicBool::new(false),
+            read_timeout: Mutex::new(None),
+            write_timeout: Mutex::new(None),
+            ttl: AtomicU32::new(64),
+            net_sock: Mutex::new(None),
+        })
+    }
+
+    pub fn socket_addr(&self) -> io::Result<SocketAddr> {
+        Ok(self.local)
+    }
+
+    pub fn peer_addr(&self) -> io::Result<SocketAddr> {
+        self.peer
+            .lock()
+            .unwrap()
+            .ok_or_else(|| io::const_error!(ErrorKind::NotConnected, "not connected"))
+    }
+
+    pub fn connect<A: ToSocketAddrs>(&self, addr: A) -> io::Result<()> {
+        *self.peer.lock().unwrap() = Some(first_addr(addr)?);
+        Ok(())
+    }
+
+    pub fn send_to(&self, buf: &[u8], dst: &SocketAddr) -> io::Result<usize> {
+        if is_loopback_or_unspec(dst) {
+            // Loopback: deliver in-process to the destination port's mailbox.
+            let mut lb = LOOPBACK.lock().unwrap();
+            if let Some(m) = lb.iter_mut().find(|m| m.port == dst.port()) {
+                m.queue.push_back((self.local, buf.to_vec()));
+            }
+            // A datagram to an unbound port is silently dropped (UDP semantics).
+            return Ok(buf.len());
+        }
+        // External: send on the wire through the net server.
+        let ip = v4_be(dst)
+            .ok_or_else(|| io::const_error!(ErrorKind::Unsupported, "oxbow net: IPv6 not supported"))?;
+        let sock = self.ensure_net_sock()?;
+        let n = unsafe { __oxbow_udp_send_to(sock, ip, dst.port(), buf.as_ptr(), buf.len()) };
+        if n < 0 {
+            Err(io::const_error!(ErrorKind::Other, "net: udp send failed"))
+        } else {
+            Ok(n as usize)
+        }
+    }
+
+    pub fn send(&self, buf: &[u8]) -> io::Result<usize> {
+        let peer = self.peer_addr()?;
+        self.send_to(buf, &peer)
+    }
+
+    fn recv_inner(&self, buf: &mut [u8], consume: bool) -> io::Result<(usize, SocketAddr)> {
+        let deadline = self.read_timeout.lock().unwrap().map(|d| Instant::now() + d);
+        loop {
+            {
+                let mut lb = LOOPBACK.lock().unwrap();
+                if let Some(m) = lb.iter_mut().find(|m| m.port == self.local.port()) {
+                    let item = if consume { m.queue.pop_front() } else { m.queue.front().cloned() };
+                    if let Some((src, data)) = item {
+                        let n = data.len().min(buf.len());
+                        buf[..n].copy_from_slice(&data[..n]);
+                        return Ok((n, src));
+                    }
+                }
+            }
+            // If this socket has done external I/O, also poll the net server (with the
+            // sender address). recv consumes, so only for `recv_from` (consume), not peek.
+            if consume {
+                if let Some(sock) = *self.net_sock.lock().unwrap() {
+                    let mut sip = 0u32;
+                    let mut sport = 0u16;
+                    let n = unsafe {
+                        __oxbow_udp_recv_from(sock, buf.as_mut_ptr(), buf.len(), &mut sip, &mut sport)
+                    };
+                    if n >= 0 {
+                        let src = SocketAddr::V4(SocketAddrV4::new(
+                            Ipv4Addr::from(sip.to_be_bytes()),
+                            sport,
+                        ));
+                        return Ok((n as usize, src));
+                    }
+                }
+            }
+            if self.nonblocking.load(Ordering::Relaxed) {
+                return Err(io::const_error!(ErrorKind::WouldBlock, "operation would block"));
+            }
+            if let Some(dl) = deadline {
+                if Instant::now() >= dl {
+                    return Err(io::const_error!(ErrorKind::WouldBlock, "recv timed out"));
+                }
+            }
+            crate::thread::yield_now();
+        }
+    }
+
+    pub fn recv_from(&self, buf: &mut [u8]) -> io::Result<(usize, SocketAddr)> {
+        self.recv_inner(buf, true)
+    }
+
+    pub fn peek_from(&self, buf: &mut [u8]) -> io::Result<(usize, SocketAddr)> {
+        self.recv_inner(buf, false)
+    }
+
+    pub fn recv(&self, buf: &mut [u8]) -> io::Result<usize> {
+        self.recv_from(buf).map(|(n, _)| n)
+    }
+
+    pub fn peek(&self, buf: &mut [u8]) -> io::Result<usize> {
+        self.peek_from(buf).map(|(n, _)| n)
+    }
+
+    pub fn duplicate(&self) -> io::Result<UdpSocket> {
+        // Clones share the bound port, hence the same mailbox queue.
+        Ok(UdpSocket {
+            local: self.local,
+            peer: Mutex::new(*self.peer.lock().unwrap()),
+            nonblocking: AtomicBool::new(self.nonblocking.load(Ordering::Relaxed)),
+            read_timeout: Mutex::new(*self.read_timeout.lock().unwrap()),
+            write_timeout: Mutex::new(*self.write_timeout.lock().unwrap()),
+            ttl: AtomicU32::new(self.ttl.load(Ordering::Relaxed)),
+            // Clones don't share the net socket; a clone re-binds on its own external send.
+            net_sock: Mutex::new(None),
+        })
+    }
+
+    fn set_timeout(slot: &Mutex<Option<Duration>>, t: Option<Duration>) -> io::Result<()> {
+        if let Some(d) = t {
+            if d == Duration::ZERO {
+                return Err(io::const_error!(
+                    ErrorKind::InvalidInput,
+                    "cannot set a 0 duration timeout",
+                ));
+            }
+        }
+        *slot.lock().unwrap() = t;
+        Ok(())
+    }
+
+    pub fn set_read_timeout(&self, t: Option<Duration>) -> io::Result<()> {
+        Self::set_timeout(&self.read_timeout, t)
+    }
+    pub fn set_write_timeout(&self, t: Option<Duration>) -> io::Result<()> {
+        Self::set_timeout(&self.write_timeout, t)
+    }
+    pub fn read_timeout(&self) -> io::Result<Option<Duration>> {
+        Ok(*self.read_timeout.lock().unwrap())
+    }
+    pub fn write_timeout(&self) -> io::Result<Option<Duration>> {
+        Ok(*self.write_timeout.lock().unwrap())
+    }
+
+    pub fn set_broadcast(&self, _: bool) -> io::Result<()> {
+        Ok(())
+    }
+    pub fn broadcast(&self) -> io::Result<bool> {
+        Ok(false)
+    }
+    pub fn set_multicast_loop_v4(&self, _: bool) -> io::Result<()> {
+        Ok(())
+    }
+    pub fn multicast_loop_v4(&self) -> io::Result<bool> {
+        Ok(false)
+    }
+    pub fn set_multicast_ttl_v4(&self, _: u32) -> io::Result<()> {
+        Ok(())
+    }
+    pub fn multicast_ttl_v4(&self) -> io::Result<u32> {
+        Ok(1)
+    }
+    pub fn set_multicast_loop_v6(&self, _: bool) -> io::Result<()> {
+        Ok(())
+    }
+    pub fn multicast_loop_v6(&self) -> io::Result<bool> {
+        Ok(false)
+    }
