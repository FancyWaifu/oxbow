+/// Resolve a host: `localhost` → loopback, literal IPv4/IPv6 directly, and any other
+/// name via a real DNS A-record query to the leased resolver (the net server's UDP path).
+pub fn lookup_host(host: &str, port: u16) -> io::Result<LookupHost> {
+    let mut addrs = VecDeque::new();
+    if host.eq_ignore_ascii_case("localhost") {
+        addrs.push_back(SocketAddr::V4(SocketAddrV4::new(Ipv4Addr::LOCALHOST, port)));
+        addrs.push_back(SocketAddr::V6(SocketAddrV6::new(Ipv6Addr::LOCALHOST, port, 0, 0)));
+    } else if let Ok(ip) = host.parse::<Ipv4Addr>() {
+        addrs.push_back(SocketAddr::V4(SocketAddrV4::new(ip, port)));
+    } else if let Ok(ip) = host.parse::<Ipv6Addr>() {
+        addrs.push_back(SocketAddr::V6(SocketAddrV6::new(ip, port, 0, 0)));
+    } else {
+        // Real DNS: query both A (IPv4) and AAAA (IPv6). v4 first so callers that try
+        // addresses in order reach a working route in IPv4-only environments.
+        let mut ip_be = 0u32;
+        if unsafe { __oxbow_dns_resolve(host.as_ptr(), host.len(), &mut ip_be) } == 0 {
+            let ip = Ipv4Addr::from(ip_be.to_be_bytes());
+            addrs.push_back(SocketAddr::V4(SocketAddrV4::new(ip, port)));
+        }
+        let mut ip16 = [0u8; 16];
+        if unsafe { __oxbow_dns_resolve6(host.as_ptr(), host.len(), ip16.as_mut_ptr()) } == 0 {
+            let ip = Ipv6Addr::from(ip16);
+            addrs.push_back(SocketAddr::V6(SocketAddrV6::new(ip, port, 0, 0)));
+        }
+        if addrs.is_empty() {
+            return Err(io::const_error!(
+                ErrorKind::Uncategorized,
+                "oxbow net: DNS resolution failed",
+            ));
+        }
+    }
+    Ok(LookupHost { addrs })
+}
diff --git a/library/std/src/sys/pal/unsupported/futex.rs b/library/std/src/sys/pal/unsupported/futex.rs
new file mode 100644
index 00000000..0bdb62a1
--- /dev/null
+++ b/library/std/src/sys/pal/unsupported/futex.rs
@@ -0,0 +1,44 @@
+//! oxbow futex — std's generic Mutex/Condvar/RwLock/Once/parking run on this,
+//! backed by oxbow-rt's hosted shims over SYS_FUTEX_WAIT/WAKE.
+#![cfg(target_os = "oxbow")]
+
+use crate::sync::atomic::Atomic;
+use crate::time::Duration;
+
+pub type Futex = Atomic<Primitive>;
+pub type Primitive = u32;
+pub type SmallFutex = Atomic<SmallPrimitive>;
+pub type SmallPrimitive = u32;
+
+unsafe extern "C" {
+    fn __oxbow_futex_wait(addr: *const u32, expected: u32, timeout_ms: u64) -> i32;
+    fn __oxbow_futex_wake(addr: *const u32) -> u32;
+    fn __oxbow_futex_wake_all(addr: *const u32);
+}
+
+#[inline]
+fn ptr(futex: &Atomic<u32>) -> *const u32 {
+    futex as *const Atomic<u32> as *const u32
+}
+
+/// Waits while `*futex == expected`. Returns false on timeout. The oxbow kernel arms a
+/// PIT-tick deadline for a `Some(timeout)` and wakes the thread when it passes; a huge
+/// timeout (std passes `u64::MAX` for an effectively-infinite `wait_timeout`) stays parked
+/// until a real `futex_wake`.
+pub fn futex_wait(futex: &Atomic<u32>, expected: u32, timeout: Option<Duration>) -> bool {
+    // ms == 0 means "no timeout" to the kernel, so a Some(_) is floored at 1 ms.
+    let ms = match timeout {
+        Some(d) => (d.as_millis().min(u64::MAX as u128) as u64).max(1),
+        None => 0,
+    };
+    // returns false on timeout, true in all other cases.
+    unsafe { __oxbow_futex_wait(ptr(futex), expected, ms) == 0 }
+}
+
+pub fn futex_wake(futex: &Atomic<u32>) -> bool {
+    unsafe { __oxbow_futex_wake(ptr(futex)) > 0 }
+}
+
+pub fn futex_wake_all(futex: &Atomic<u32>) {
+    unsafe { __oxbow_futex_wake_all(ptr(futex)) };
+}
