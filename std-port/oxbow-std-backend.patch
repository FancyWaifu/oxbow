+impl fmt::Debug for TcpStream {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        f.debug_struct("TcpStream").finish_non_exhaustive()
+    }
+}
+
+impl TcpListener {
+    pub fn bind<A: ToSocketAddrs>(addr: A) -> io::Result<TcpListener> {
+        let addr = first_addr(addr)?;
+        let is_loop = match &addr {
+            SocketAddr::V4(s) => s.ip().is_loopback(),
+            SocketAddr::V6(s) => s.ip().is_loopback(),
+        };
+        let is_any = addr.ip().is_unspecified();
+        if is_loop {
+            // In-process loopback listener.
+            let port = if addr.port() == 0 {
+                TCP_EPHEMERAL.fetch_add(1, Ordering::Relaxed) as u16
+            } else {
+                addr.port()
+            };
+            let addr = loopback_like(&addr, port);
+            let mut ls = LISTENERS.lock().unwrap();
+            if ls.iter().any(|e| e.addr == addr) {
+                return Err(io::const_error!(ErrorKind::AddrInUse, "address in use"));
+            }
+            let id = NEXT_LID.fetch_add(1, Ordering::Relaxed);
+            ls.push(ListenerEntry { id, addr, queue: VecDeque::new(), nonblocking: false, ttl: 64 });
+            Ok(TcpListener(ListenerKind::Loop { id, addr }))
+        } else if is_any {
+            // Wire listener: a real listening socket in the net server.
+            let sock = unsafe { __oxbow_tcp_listen(addr.port()) };
+            if sock < 0 {
+                return Err(io::const_error!(ErrorKind::AddrInUse, "net: could not listen"));
+            }
+            Ok(TcpListener(ListenerKind::Net(Arc::new(NetListener {
+                sock,
+                addr,
+                nonblocking: AtomicBool::new(false),
+            }))))
+        } else {
+            // A specific non-local address can't be bound.
+            Err(io::const_error!(ErrorKind::AddrNotAvailable, "oxbow net: address not available"))
+        }
+    }
+    pub fn socket_addr(&self) -> io::Result<SocketAddr> {
+        Ok(match &self.0 {
+            ListenerKind::Loop { addr, .. } => *addr,
+            ListenerKind::Net(l) => l.addr,
+        })
+    }
+    pub fn accept(&self) -> io::Result<(TcpStream, SocketAddr)> {
+        match &self.0 {
+            ListenerKind::Loop { id, .. } => loop {
+                let (conn, nonblocking) = {
+                    let mut ls = LISTENERS.lock().unwrap();
+                    let e = ls.iter_mut().find(|e| e.id == *id).ok_or_else(|| {
+                        io::const_error!(ErrorKind::NotConnected, "listener closed")
+                    })?;
+                    (e.queue.pop_front(), e.nonblocking)
+                };
+                if let Some(conn) = conn {
+                    let caddr = conn.caddr;
+                    return Ok((TcpStream(Stream::Loop(Arc::new(new_endpoint(conn, true)))), caddr));
+                }
+                if nonblocking {
+                    return Err(io::const_error!(ErrorKind::WouldBlock, "operation would block"));
+                }
+                crate::thread::yield_now();
+            },
+            ListenerKind::Net(l) => loop {
+                let mut a = [0u8; 16];
+                let mut v6 = 0u8;
+                let mut sport = 0u16;
+                let sock =
+                    unsafe { __oxbow_tcp_accept(l.sock, a.as_mut_ptr(), &mut v6, &mut sport) };
+                if sock >= 0 {
+                    let peer = if v6 != 0 {
+                        SocketAddr::V6(SocketAddrV6::new(Ipv6Addr::from(a), sport, 0, 0))
+                    } else {
+                        let mut v4 = [0u8; 4];
+                        v4.copy_from_slice(&a[..4]);
+                        SocketAddr::V4(SocketAddrV4::new(Ipv4Addr::from(v4), sport))
+                    };
+                    let stream = TcpStream(Stream::Net(Arc::new(NetStream { sock, peer })));
+                    return Ok((stream, peer));
+                }
+                if l.nonblocking.load(Ordering::Relaxed) {
+                    return Err(io::const_error!(ErrorKind::WouldBlock, "operation would block"));
+                }
+                crate::thread::yield_now();
+            },
+        }
+    }
+    pub fn duplicate(&self) -> io::Result<TcpListener> {
+        Ok(TcpListener(match &self.0 {
+            ListenerKind::Loop { id, addr } => ListenerKind::Loop { id: *id, addr: *addr },
+            ListenerKind::Net(l) => ListenerKind::Net(l.clone()),
+        }))
+    }
+    pub fn set_ttl(&self, ttl: u32) -> io::Result<()> {
+        if let ListenerKind::Loop { id, .. } = &self.0 {
+            let mut ls = LISTENERS.lock().unwrap();
+            if let Some(e) = ls.iter_mut().find(|e| e.id == *id) {
+                e.ttl = ttl;
+            }
+        }
+        Ok(())
+    }
+    pub fn ttl(&self) -> io::Result<u32> {
+        match &self.0 {
+            ListenerKind::Loop { id, .. } => {
+                let ls = LISTENERS.lock().unwrap();
+                Ok(ls.iter().find(|e| e.id == *id).map(|e| e.ttl).unwrap_or(64))
+            }
+            ListenerKind::Net(_) => Ok(64),
+        }
+    }
+    pub fn set_only_v6(&self, _: bool) -> io::Result<()> {
+        unsupported()
+    }
+    pub fn only_v6(&self) -> io::Result<bool> {
+        unsupported()
+    }
+    pub fn take_error(&self) -> io::Result<Option<io::Error>> {
+        Ok(None)
+    }
+    pub fn set_nonblocking(&self, nonblocking: bool) -> io::Result<()> {
+        match &self.0 {
+            ListenerKind::Loop { id, .. } => {
+                let mut ls = LISTENERS.lock().unwrap();
+                if let Some(e) = ls.iter_mut().find(|e| e.id == *id) {
+                    e.nonblocking = nonblocking;
+                }
+            }
+            ListenerKind::Net(l) => l.nonblocking.store(nonblocking, Ordering::Relaxed),
+        }
+        Ok(())
+    }
+}
+
